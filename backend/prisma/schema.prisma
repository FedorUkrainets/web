generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ENGINEER
  ADMIN
  DIRECTOR
}

enum ChargingSessionStatus {
  CREATED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum StationStatus {
  CREATED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ChargerStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  fullName         String
  role             UserRole          @default(USER)
  chargingSessions ChargingSession[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ChargingStation {
  id               String            @id @default(cuid())
  name             String
  code             String            @unique
  address          String
  city             String?
  status           StationStatus     @default(CREATED)
  capacityKw       Float             @default(0)
  currentLoadKw    Float             @default(0)
  totalChargers    Int               @default(1)
  activeChargers   Int               @default(0)
  revenue          Float             @default(0)
  lastMaintenanceAt DateTime?
  notes            String?
  connectors       Connector[]
  chargingSessions ChargingSession[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Connector {
  id               String            @id @default(cuid())
  stationId        String
  station          ChargingStation   @relation(fields: [stationId], references: [id], onDelete: Cascade)
  label            String
  type             String
  powerKw          Float
  status           ChargerStatus     @default(AVAILABLE)
  isAvailable      Boolean           @default(true)
  chargingSessions ChargingSession[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ChargingSession {
  id         String                @id @default(cuid())
  userId     String
  stationId  String
  connectorId String
  user       User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  station    ChargingStation       @relation(fields: [stationId], references: [id], onDelete: Restrict)
  connector  Connector             @relation(fields: [connectorId], references: [id], onDelete: Restrict)
  status     ChargingSessionStatus @default(CREATED)
  startedAt  DateTime?
  endedAt    DateTime?
  energyKwh  Float?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}
